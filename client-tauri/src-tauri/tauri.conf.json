{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OJIK BMS Client",
  "version": "1.0.0-beta.1",
  "identifier": "kr.ojikbms.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OJIK BMS Client",
        "width": 1120,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false,
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "Korean",
          "English"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "TAURI_UPDATER_PUBLIC_KEY_NOT_CONFIGURED",
      "endpoints": [
        "https://api.ojikbms.kr/client/tauri-update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
