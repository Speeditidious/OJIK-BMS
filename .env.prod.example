# =============================================================================
# OJIK BMS — Production Environment Variables
# Copy this file to .env.prod and fill in real values.
# docker-compose.prod.yml loads this file for every service.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=ojik
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=ojik_bms

# --- Security ---
# Generate with: openssl rand -hex 64
SECRET_KEY=CHANGE_ME_at_least_64_char_random_string

# --- Discord OAuth ---
DISCORD_CLIENT_ID=your_discord_app_client_id
DISCORD_CLIENT_SECRET=your_discord_app_client_secret
DISCORD_REDIRECT_URI=your_redirect_url

# --- Frontend ---
FRONTEND_URL=your_domain_url
CORS_ORIGINS=["your_domain_url"]

# --- Cloudflare R2 (backup storage) ---
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=ojik-bms-backups
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# --- LLM (optional, leave empty to disable) ---
LLM_PROVIDER=ollama
LLM_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=